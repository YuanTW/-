# ════════════════════════════════════════════════════════════════
#  量化交易儀表板 — 環境變數範本
#  複製此檔案為 .env，填入實際值後在本地執行
#  部署到 Railway 時，直接在 Railway 平台的 Variables 頁面設定
# ════════════════════════════════════════════════════════════════

# ── 資料庫 ──────────────────────────────────────────────────────
# 本地開發：留空即自動使用 SQLite（不需安裝 PostgreSQL）
# Railway：平台會自動注入，不需手動設定
DATABASE_URL=

# ── Telegram ────────────────────────────────────────────────────
# 從 @BotFather 取得
TELEGRAM_BOT_TOKEN=你的Bot Token

# 你的 Telegram 使用者 ID（數字）
TELEGRAM_CHAT_ID=你的Chat ID

# ── 儀表板顯示 ───────────────────────────────────────────────────
DASHBOARD_TITLE=量化交易儀表板
DASHBOARD_SUBTITLE=Quantitative Trading Monitor

# ── 時區 ────────────────────────────────────────────────────────
TIMEZONE=Asia/Taipei
